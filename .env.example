# ── MCP Financial Tools Server — Variables de Entorno ─────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Base de Datos (para query_kpis en producción) ──────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/financial_db
# BigQuery alternativo:
# BIGQUERY_PROJECT=my-project
# BIGQUERY_DATASET=financial_data
# GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# ── Servidor ──────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Opcionales ─────────────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=           # Para tracing con LangSmith
# LANGSMITH_PROJECT=mcp-financial-tools
# SENTRY_DSN=                  # Para error tracking en producción
